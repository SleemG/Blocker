        if files:
            try:
                conn = sqlite3.connect('app_blocker.db')
                cursor = conn.cursor()
                
                count = 0
                for file in files:
                    app_name = os.path.basename(file)
                    cursor.execute('INSERT INTO whitelist_apps (email, app_path, app_name) VALUES (?, ?, ?)',
                                 (self.user_email, file, app_name))
                    
                    item = QListWidgetItem(QIcon(file), app_name)
                    item.setData(Qt.UserRole, file)
                    self.listWidget_3.addItem(item)  # Changed to listWidget_3 for apps tab
                    count += 1
                
                conn.commit()
                self.show_status_message(f"Added {count} {'application' if count == 1 else 'applications'} to whitelist")
            except sqlite3.Error as e:
