    def add_whitelist_apps(self):
        files, _ = QFileDialog.getOpenFileNames(self, "Select Applications", "", "Applications (*.exe)")
        if files:
            count = 0
            for file in files:
                item = QListWidgetItem(QIcon(file), file)
                self.listWidget_3.addItem(item)  # Changed to listWidget_3 for apps tab
                count += 1
            self.show_status_message(f"Added {count} {'application' if count == 1 else 'applications'} to whitelist")
        else:
            self.show_status_message("No applications selected", 2000)

    def remove_whitelist_apps(self):
        items = self.listWidget_3.selectedItems()  # Changed to listWidget_3 for apps tab
        if items:
            for item in items:
                self.listWidget_3.takeItem(self.listWidget_3.row(item))
            count = len(items)
            self.show_status_message(f"Removed {count} {'application' if count == 1 else 'applications'} from whitelist")
        else:
            self.show_status_message("Please select applications to remove from whitelist", 2000)

    def get_all_websites(self):
        return [self.listWidget.item(i).text() for i in range(self.listWidget.count())]

    def get_all_apps(self):
        return [self.listWidget_2.item(i).text() for i in range(self.listWidget_2.count())]

    def get_all_whitelist_websites(self):
        return [self.listWidget_3.item(i).text() for i in range(self.listWidget_3.count())]

    def show_status_message(self, message, timeout=3000):
        """Show a message in the status bar for a specified time (in milliseconds)"""
        self.status_bar.showMessage(message)
        self.status_timer.start(timeout)

    def on_email_verified(self, email):
        """Called when email verification is successful"""
        self.user_email = email
        self.show_status_message(f"Welcome, {email}!")
        self.load_user_data()
        
    def load_user_data(self):
        """Load user's saved data from database"""
        try:
            conn = sqlite3.connect('app_blocker.db')
            cursor = conn.cursor()
            
            # Create tables if they don't exist
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS users (
                    email TEXT PRIMARY KEY
                )
            ''')
            
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS blocked_websites (
                    email TEXT,
                    website TEXT,
                    FOREIGN KEY (email) REFERENCES users (email)
                )
            ''')
            
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS blocked_apps (
                    email TEXT,
                    app_path TEXT,
                    app_name TEXT,
                    FOREIGN KEY (email) REFERENCES users (email)
                )
            ''')
            
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS whitelist_websites (
                    email TEXT,
                    website TEXT,
                    FOREIGN KEY (email) REFERENCES users (email)
                )
            ''')
            
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS whitelist_apps (
                    email TEXT,
                    app_path TEXT,
                    app_name TEXT,
                    FOREIGN KEY (email) REFERENCES users (email)
                )
            ''')
            
            # Insert or update user
            cursor.execute('INSERT OR IGNORE INTO users (email) VALUES (?)', (self.user_email,))
            
            # Load blocked websites
            cursor.execute('SELECT website FROM blocked_websites WHERE email = ?', (self.user_email,))
            websites = cursor.fetchall()
            for website in websites:
                self.listWidget.addItem(website[0])
            
            # Load blocked apps
            cursor.execute('SELECT app_path, app_name FROM blocked_apps WHERE email = ?', (self.user_email,))
            apps = cursor.fetchall()
            for app_path, app_name in apps:
                item = QListWidgetItem(QIcon(app_path), app_name)
                item.setData(Qt.UserRole, app_path)
                self.listWidget_2.addItem(item)
            
            # Load whitelist websites
            cursor.execute('SELECT website FROM whitelist_websites WHERE email = ?', (self.user_email,))
            websites = cursor.fetchall()
            for website in websites:
                self.listWidget_4.addItem(website[0])
            
            # Load whitelist apps
            cursor.execute('SELECT app_path, app_name FROM whitelist_apps WHERE email = ?', (self.user_email,))
            apps = cursor.fetchall()
            for app_path, app_name in apps:
                item = QListWidgetItem(QIcon(app_path), app_name)
                item.setData(Qt.UserRole, app_path)
                self.listWidget_3.addItem(item)
                
            conn.commit()
            
        except sqlite3.Error as e:
            QMessageBox.warning(self, "Database Error", f"Failed to load user data: {str(e)}")
        finally:
            conn.close()

    def clear_status_message(self):
        """Clear the status bar message and show 'Ready'"""
        self.status_bar.showMessage("Ready")

def load_stylesheet():
    """Load and combine all QSS stylesheets, replacing font-family with Arial."""
    list_stylesheets = [
        "App GUI.qss",  
        "Account Details.qss",
        "Accountability Partners.qss",
        "addFocus Timer.qss",
        "SignUp.qss",
    ]
    style_str = ""
    for stylesheet in list_stylesheets:
        try:
            with open(f"GUI/{stylesheet}", "r") as file:
                qss = file.read()
                style_str += qss
        except FileNotFoundError:
            print(f"Warning: {stylesheet} not found.")
    return style_str

def fade_in_widget(widget, duration=300):
    effect = QGraphicsOpacityEffect()
    widget.setGraphicsEffect(effect)
    animation = QPropertyAnimation(effect, b"opacity")
    animation.setDuration(duration)
    animation.setStartValue(0)
    animation.setEndValue(1)
    animation.setEasingCurve(QEasingCurve.InOutQuad)
    animation.start()
    # Keep a reference to avoid garbage collection
    widget._fade_animation = animation

if __name__ == "__main__":
    app = QApplication(sys.argv)

    # Load and apply the stylesheet
    style_str = load_stylesheet()
    if style_str:
        app.setStyleSheet(style_str)
    else:
        print("No stylesheets loaded. Using default style.")

    main_window = MainWindow()
    main_window.show()
    sys.exit(app.exec_())