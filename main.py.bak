                conn.close()
    def verify_code(self):
        entered_code = self.lineEdit_2.text()
        if entered_code == self.verification_code:
            self.verified.emit(self.email)
            self.accept()
        else:
            QMessageBox.warning(self, "Invalid Code", "The verification code is incorrect. Please try again.")
    
    def code_timeout(self):
        """Called when verification code expires"""
        self.verification_code = None
        QMessageBox.warning(self, "Code Expired", 
                          "The verification code has expired. Please go back and request a new one.")

    def send_verification_code(self):
        self.pushButton.setEnabled(False)
        self.email = self.lineEdit.text()
        # Generate a 6-digit verification code
        self.verification_code = ''.join([str(random.randint(0, 9)) for _ in range(6)])
        
        try:
            # Email configuration
            # Ensure verification table exists
            self._create_verification_table()
            
            # Store verification code in database
            conn = sqlite3.connect('app_blocker.db')
            cursor = conn.cursor()
            
            # Delete any existing code for this email
            cursor.execute('DELETE FROM verification_codes WHERE email = ?', (self.email,))
            
            # Store the new code
            cursor.execute('INSERT INTO verification_codes (email, code) VALUES (?, ?)', 
                         (self.email, self.verification_code))
            
            conn.commit()
            conn.close()
            
            # Show verification code to user
            QMessageBox.information(self, "Verification Code", 
                f"Your verification code is: {self.verification_code}\n\n"
                "Please enter this code on the next screen to verify your email.\n"
                "The code will expire in 5 minutes.")
            
            # Start expiration timer and switch to verification page
            self.code_timer.start(5 * 60 * 1000)  # 5 minutes
            self.stackedWidget.setCurrentIndex(1)
            
            # Re-enable the send button after 1 minute
            QTimer.singleShot(60 * 1000, lambda: self.pushButton.setEnabled(True))
            
        except sqlite3.Error as e:
            QMessageBox.critical(self, "Database Error", f"Failed to store verification code: {str(e)}")
            self.pushButton.setEnabled(True)


    def verify_code(self):
        """Verify the entered code"""
        entered_code = self.lineEdit_2.text().strip()
        
        try:
            conn = sqlite3.connect('app_blocker.db')
            cursor = conn.cursor()
            
            # Get the stored code and timestamp
            cursor.execute('''
                SELECT code, timestamp, 
                    ROUND((JULIANDAY('now') - JULIANDAY(timestamp)) * 24 * 60) as minutes_diff 
                FROM verification_codes 
                WHERE email = ?
            ''', (self.email,))
            
            result = cursor.fetchone()
            
            if not result:
                QMessageBox.warning(self, "Invalid Code", 
                    "No verification code found. Please request a new one.")
                return
                
            stored_code, timestamp, minutes_diff = result
            
            # Check if code is expired (older than 5 minutes)
            if minutes_diff > 5:
                cursor.execute('DELETE FROM verification_codes WHERE email = ?', (self.email,))
                conn.commit()
                QMessageBox.warning(self, "Code Expired", 
                    "The verification code has expired. Please request a new one.")
                self.stackedWidget.setCurrentIndex(0)  # Go back to email entry
                self.pushButton.setEnabled(True)  # Allow requesting new code
                return
                
            # Verify the code
            if entered_code == stored_code:
                # Delete the used code
                cursor.execute('DELETE FROM verification_codes WHERE email = ?', (self.email,))
                conn.commit()
                self.code_verified.emit(self.email)
                self.accept()
            else:
                QMessageBox.warning(self, "Invalid Code", 
                    "The verification code is incorrect. Please try again.")
                
        except sqlite3.Error as e:
            QMessageBox.critical(self, "Database Error",
                f"Failed to verify code: {str(e)}")
        finally:
            conn.close()
            
    def code_expired(self):
        """Handle code expiration"""
        try:
            conn = sqlite3.connect('app_blocker.db')
            cursor = conn.cursor()
            
            # Delete expired code
            cursor.execute('DELETE FROM verification_codes WHERE email = ?', (self.email,))
            conn.commit()
            
            QMessageBox.warning(self, "Code Expired", 
                "The verification code has expired. Please request a new one.")
            self.stackedWidget.setCurrentIndex(0)  # Go back to email entry
            self.pushButton.setEnabled(True)  # Enable resend button
            self.cooldown_timer.stop()  # Reset cooldown timer
            
        except sqlite3.Error as e:
            QMessageBox.critical(self, "Database Error",
                f"Failed to handle code expiration: {str(e)}")
        finally:
            conn.close()
            
class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        
        try:
            # Create database and tables
            conn = sqlite3.connect('app_blocker.db')
            cursor = conn.cursor()
            
            # Create tables
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS users (
                    email TEXT PRIMARY KEY
                )
            ''')
            
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS blocked_websites (
                    email TEXT,
                    website TEXT,
                    FOREIGN KEY (email) REFERENCES users (email)
                )
            ''')
            
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS blocked_apps (
                    email TEXT,
                    app_path TEXT,
                    app_name TEXT,
                    FOREIGN KEY (email) REFERENCES users (email)
                )
            ''')
            
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS whitelist_websites (
                    email TEXT,
                    website TEXT,
                    FOREIGN KEY (email) REFERENCES users (email)
                )
            ''')
            
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS whitelist_apps (
                    email TEXT,
                    app_path TEXT,
                    app_name TEXT,
                    FOREIGN KEY (email) REFERENCES users (email)
                )
            ''')
            
            conn.commit()
        except sqlite3.Error as e:
            QMessageBox.critical(None, "Database Error",
                               f"Failed to initialize database: {str(e)}\nThe application will now exit.")
            sys.exit(1)
        finally:
            conn.close()
        
        # Show signup dialog first
        signup_dialog = SignUpDialog(self)
        signup_dialog.verified.connect(self.on_email_verified)
        if signup_dialog.exec_() != QDialog.Accepted:
            sys.exit(0)
            
        # Load only the main UI file into the main window after successful signup
        loadUi(r"GUI\App GUI.ui", self)

        # Create and set status bar
        self.status_bar = QStatusBar()
        self.setStatusBar(self.status_bar)
        self.status_bar.showMessage("Ready")

        # Create timer for status bar messages
        self.status_timer = QTimer()
        self.status_timer.timeout.connect(self.clear_status_message)
        self.status_timer.setSingleShot(True)  # Timer runs only once

        # Load other UIs first
        self.other_ui_files = [
            "Account Details.ui",
            "Accountability Partners.ui",
            "addFocus Timer.ui"
        ]
        self.other_widgets = {}
        for ui_file in self.other_ui_files:
            widget = QWidget()
            loadUi(f"GUI/{ui_file}", widget)
            self.other_widgets[ui_file] = widget

        # Set initial state
        self.blockList_btn.setChecked(True)
        self.whiteList_btn.setChecked(False)
        self.stackedWidget_blkLst.setCurrentWidget(self.BlockList_page)

        # These are already checkable in the .ui file
        self.blockList_btn.clicked.connect(self.show_block_list_page)
        self.whiteList_btn.clicked.connect(self.show_white_list_page)

        # Connect Add/Remove buttons to their slots
        self.pushButton_8.clicked.connect(self.add_website)   # Add website/keyword
        self.pushButton_9.clicked.connect(self.remove_website) # Remove website/keyword
        self.pushButton_10.clicked.connect(self.add_apps)     # Add apps
        self.pushButton_11.clicked.connect(self.remove_apps)  # Remove apps

        # White List tab connections
        self.pushButton_13.clicked.connect(self.add_whitelist_website)   # Add website/keyword to white list
        self.pushButton_12.clicked.connect(self.remove_whitelist_website) # Remove website/keyword from white list
        self.pushButton_15.clicked.connect(self.add_whitelist_apps)     # Add apps to white list
        self.pushButton_14.clicked.connect(self.remove_whitelist_apps)  # Remove whitelist apps button

    def show_block_list_page(self):
        self.blockList_btn.setChecked(True)
        self.whiteList_btn.setChecked(False)
        self.stackedWidget_blkLst.setCurrentWidget(self.BlockList_page)
        fade_in_widget(self.BlockList_page)

    def show_white_list_page(self):
        self.stackedWidget_blkLst.setCurrentWidget(self.WhiteList_page)
        self.whiteList_btn.setChecked(True)
        self.blockList_btn.setChecked(False)
        fade_in_widget(self.WhiteList_page)

    def add_website(self):
        text = self.lineEdit.text().strip()
        if text:
            try:
                conn = sqlite3.connect('app_blocker.db')
                cursor = conn.cursor()
                cursor.execute('INSERT INTO blocked_websites (email, website) VALUES (?, ?)',
                             (self.user_email, text))
                conn.commit()
                
                self.listWidget.addItem(text)
                self.lineEdit.clear()
                self.show_status_message(f"Added website/keyword: {text}")
            except sqlite3.Error as e:
                QMessageBox.warning(self, "Database Error", f"Failed to save website: {str(e)}")
            finally:
                conn.close()
        else:
            self.show_status_message("Please enter a website or keyword", 2000)

    def remove_website(self):
        items = self.listWidget.selectedItems()
        if items:
            try:
                conn = sqlite3.connect('app_blocker.db')
                cursor = conn.cursor()
                for item in items:
                    text = item.text()
                    cursor.execute('DELETE FROM blocked_websites WHERE email = ? AND website = ?',
                                 (self.user_email, text))
                    self.listWidget.takeItem(self.listWidget.row(item))
                
                conn.commit()
                count = len(items)
                self.show_status_message(f"Removed {count} {'item' if count == 1 else 'items'}")
            except sqlite3.Error as e:
                QMessageBox.warning(self, "Database Error", f"Failed to remove website(s): {str(e)}")
            finally:
                conn.close()
        else:
            self.show_status_message("Please select items to remove", 2000)

    def get_installed_apps(self):
        apps = []
        # Check both 32-bit and 64-bit registry
        for hkey in (winreg.HKEY_LOCAL_MACHINE, winreg.HKEY_CURRENT_USER):
            for flag in (winreg.KEY_WOW64_32KEY, winreg.KEY_WOW64_64KEY):
                try:
                    reg_key = winreg.OpenKey(hkey, r"SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall", 
                                           0, winreg.KEY_READ | flag)
                    
                    for i in range(winreg.QueryInfoKey(reg_key)[0]):
                        try:
                            subkey_name = winreg.EnumKey(reg_key, i)
                            subkey = winreg.OpenKey(reg_key, subkey_name)
                            try:
                                display_name = winreg.QueryValueEx(subkey, "DisplayName")[0]
                                install_location = winreg.QueryValueEx(subkey, "InstallLocation")[0]
                                if display_name and install_location:
                                    # Look for the .exe file in the install location
                                    for root, _, files in os.walk(install_location):
                                        for file in files:
                                            if file.lower().endswith('.exe'):
                                                exe_path = os.path.join(root, file)
                                                apps.append((display_name, exe_path))
                                                break
                            except (WindowsError, KeyError):
                                continue
                            finally:
                                winreg.CloseKey(subkey)
                        except WindowsError:
                            continue
                except WindowsError:
                    continue
                finally:
                    try:
                        winreg.CloseKey(reg_key)
                    except WindowsError:
                        continue
        return sorted(set(apps))  # Remove duplicates and sort

    class AppSelectionDialog(QDialog):
        def __init__(self, apps, parent=None):
            super().__init__(parent)
            self.setWindowTitle("Select Applications")
            self.setModal(True)
            self.resize(600, 400)

            layout = QVBoxLayout(self)
            
            # Create list widget with checkboxes
            self.list_widget = QListWidget()
            self.list_widget.setSelectionMode(QListWidget.MultiSelection)
            for name, path in apps:
                item = QListWidgetItem(f"{name} ({path})")
                item.setData(Qt.UserRole, path)  # Store the path
                item.setIcon(QIcon(path))
                self.list_widget.addItem(item)
            
            layout.addWidget(self.list_widget)
            
            # Add OK/Cancel buttons
            button_box = QDialogButtonBox(QDialogButtonBox.Ok | QDialogButtonBox.Cancel)
            button_box.accepted.connect(self.accept)
            button_box.rejected.connect(self.reject)
            layout.addWidget(button_box)

    def add_apps(self):
        self.show_status_message("Loading installed applications...", 0)  # 0 means no timeout
        apps = self.get_installed_apps()
        dialog = self.AppSelectionDialog(apps, self)
        self.show_status_message("Select applications to add")
        
        if dialog.exec_() == QDialog.Accepted:
            try:
                conn = sqlite3.connect('app_blocker.db')
                cursor = conn.cursor()
                
                count = 0
                for item in dialog.list_widget.selectedItems():
                    path = item.data(Qt.UserRole)
                    app_name = item.text()
                    
                    cursor.execute('INSERT INTO blocked_apps (email, app_path, app_name) VALUES (?, ?, ?)',
                                 (self.user_email, path, app_name))
                    
                    list_item = QListWidgetItem(QIcon(path), item.text())
                    list_item.setData(Qt.UserRole, path)
                    self.listWidget_2.addItem(list_item)
                    count += 1
                
                conn.commit()
                self.show_status_message(f"Added {count} {'application' if count == 1 else 'applications'}")
            except sqlite3.Error as e:
                QMessageBox.warning(self, "Database Error", f"Failed to save application(s): {str(e)}")
            finally:
                conn.close()
        else:
            self.show_status_message("Ready")

    def remove_apps(self):
        items = self.listWidget_2.selectedItems()
        if items:
            try:
                conn = sqlite3.connect('app_blocker.db')
                cursor = conn.cursor()
                
                for item in items:
